# ==================================================================
# .gitignore — mi_plataforma_multitienda
# ==================================================================

# ------------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ------------------------------------------------------------------
# ENTORNOS VIRTUALES
# ------------------------------------------------------------------
env/
venv/
.venv/
ENV/

# ------------------------------------------------------------------
# VARIABLES DE ENTORNO Y SECRETOS
# ⚠️ NUNCA subir estos archivos al repositorio
# ------------------------------------------------------------------
.env
.env.*
secrets/
*.json.key
google-credentials.json
*credentials*.json
*service-account*.json

# ------------------------------------------------------------------
# DJANGO
# ------------------------------------------------------------------
db.sqlite3
db.sqlite3-journal
mediafiles/
staticfiles/

# ------------------------------------------------------------------
# GOOGLE CLOUD
# ------------------------------------------------------------------
*.json
!package.json
!package-lock.json

# ------------------------------------------------------------------
# NODE / TAILWIND / VITE
# ------------------------------------------------------------------
node_modules/
dist/
.npm
npm-debug.log*

# ------------------------------------------------------------------
# IDEs
# ------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ------------------------------------------------------------------
# SISTEMA OPERATIVO
# ------------------------------------------------------------------
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ------------------------------------------------------------------
# LOGS Y TEMPORALES
# ------------------------------------------------------------------
*.log
*.pot
*.pyc
.cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ------------------------------------------------------------------
# MIGRACIONES (opcional — algunos equipos las incluyen)
# Descomenta si NO quieres subir migraciones al repo.
# Para un proyecto en solitario es mejor INCLUIRLAS (dejar comentado).
# ------------------------------------------------------------------
# */migrations/0*.py